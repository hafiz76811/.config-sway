# background, warna teks, dan jenis font
background-color=#3f3f3f
text-color=#ffffff
font=DejaVu Sans 12

# lebar dan tinggi jendela
width=300
height=150

# margin dan padding jendela
margin=10
padding=10
anchor=top-right

# pengaturan border jendela
border-size=3
border-radius=10

# pengaturan icons
icons=true
icon-location=left
icon-path=/usr/share/icons/hicolor:/usr/share/icons/Adwaita
max-icon-size=100
icon-border-radius=10

# lapisan dan history
layer=top
history=true
max-history=10
sort=+time

# timeout dari jendela mako
ignore-timeout=true
default-timeout=20000

# urgencies mode
[urgency=low]
border-color=#5fdf5f

[urgency=normal]
border-color=#5f5fff

[urgency=high]
border-color=#ff5f5f
